@using BookSoft.Facade.DTOs
@using BookSoft.Facade.UseCases
@inject IAddClinicUseCase AddClinicUseCase
@inject IUpdateClinicUseCase UpdateClinicUseCase
@inject IRemoveClinicUseCase RemoveClinicUseCase

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal" @onclick:stopPropagation>
            <h3>@(Clinic == null ? "Ny klinik" : "Rediger klinik")</h3>

            <label>Kliniknavnet</label>
            <input @bind="navn" placeholder="fx Østerbro Fysioterapi" />

            @if (errorMsg != null)
            {
                <p class="error-msg">@errorMsg</p>
            }

            <div class="modal-buttons">
                @if (Clinic != null)
                {
                    <button class="btn-slet" @onclick="Delete" disabled="@saving">Slet</button>
                }
                <button class="btn-annuller" @onclick="Cancel">Annuller</button>
                <button class="btn-gem" @onclick="Save" disabled="@saving">Gem</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public ClinicDto? Clinic { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    string navn = "";
    string? errorMsg;
    bool saving;

    protected override void OnParametersSet()
    {
        if (!IsVisible) return;
        navn = Clinic?.ClinicName ?? "";
        errorMsg = null;
    }

    async Task Save()
    {
        errorMsg = null;
        if (string.IsNullOrWhiteSpace(navn)) { errorMsg = "Klinikkens navn er påkrævet."; return; }
        saving = true;
        try
        {
            if (Clinic == null)
                await AddClinicUseCase.Run(new AddClinicRequest(navn.Trim()));
            else
                await UpdateClinicUseCase.Run(new UpdateClinicRequest(Clinic.Id, navn.Trim()));

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    async Task Delete()
    {
        if (Clinic == null) return;
        saving = true;
        try
        {
            await RemoveClinicUseCase.Run(Clinic.Id);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    async Task Cancel() => await OnCancelled.InvokeAsync();
}
