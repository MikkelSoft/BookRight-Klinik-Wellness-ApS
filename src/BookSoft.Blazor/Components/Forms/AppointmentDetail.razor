@inject ICancelAppointmentUseCase CancelUseCase
@inject IFinishAppointmentUseCase FinishUseCase
@using BookSoft.Facade.UseCases
@using BookSoft.Facade.DTOs

<div class="detail-card">

    <h3>Appointment</h3>

    <div class="detail-row">
        <span class="detail-label">Patient</span>
        <span class="detail-value">@Appointment.PatientFullNameString</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Practitioner</span>
        <span class="detail-value">@Appointment.PractitionerFullNameString</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Clinic</span>
        <span class="detail-value">@Appointment.ClinicName</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Type</span>
        <span class="detail-value">@Appointment.AppointmentTypeString</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Start</span>
        <span class="detail-value">@Appointment.AppointmentStartTime.ToString("dd/MM/yyyy HH:mm")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">End</span>
        <span class="detail-value">@Appointment.AppointmentEndTime.ToString("HH:mm")</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Price</span>
        <span class="detail-value">@Appointment.Pris.ToString("N0") kr</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Discount</span>
        <span class="detail-value discount">@(Appointment.AnvendtRabatType ?? "None")</span>
    </div>

    @if (errorMessage != null)
    {
        <p class="error-msg">@errorMessage</p>
    }

    <div class="action-buttons">
        <button class="btn-finish" @onclick="Finish" disabled="@working">
            @(working ? "..." : "Finish")
        </button>
        <button class="btn-cancel-appt" @onclick="Cancel" disabled="@working">
            @(working ? "..." : "Cancel")
        </button>
        <button class="btn-close" @onclick="OnClose">Close</button>
    </div>

</div>

@code {
    [Parameter] public AppointmentDto Appointment { get; set; } = default!;
    [Parameter] public EventCallback  OnClose     { get; set; }

    bool    working = false;
    string? errorMessage;

    async Task Finish()
    {
        working = true;
        errorMessage = null;
        try
        {
            await FinishUseCase.Run(Appointment.Id);
            await OnClose.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            working = false;
        }
    }

    async Task Cancel()
    {
        working = true;
        errorMessage = null;
        try
        {
            await CancelUseCase.Run(new CancelAppointmentRequest(Appointment.Id));
            await OnClose.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            working = false;
        }
    }
}
