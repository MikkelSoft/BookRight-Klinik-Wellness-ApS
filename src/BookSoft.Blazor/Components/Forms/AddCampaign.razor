@using BookSoft.Facade.DTOs
@using BookSoft.Facade.UseCases
@using BookSoft.Domain.Enums
@inject IAddCampaignUseCase AddCampaignUseCase
@inject IRemoveCampaignUseCase RemoveCampaignUseCase

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal" @onclick:stopPropagation>
            <h3>@(Campaign == null ? "Ny kampagne" : Campaign.Navn)</h3>

            @if (Campaign == null)
            {
                <label>Kampagnenavn</label>
                <input @bind="navn" placeholder="fx Forårskampagne 2026" />

                <label>Rabatprocent (%)</label>
                <input @bind="discountPct" type="number" min="1" max="100" placeholder="fx 20" />

                <label>Startdato</label>
                <input @bind="startDato" type="date" />

                <label>Slutdato</label>
                <input @bind="slutDato" type="date" />

                <label>Gælder for (tomt = alle behandlingstyper)</label>
                <div class="checkbox-group">
                    @foreach (var t in Enum.GetValues<AppointmentTypeEnum>())
                    {
                        <label class="checkbox-label">
                            <input type="checkbox"
                                   checked="@validFor.Contains(t)"
                                   @onchange="e => ToggleType(t, (bool)e.Value!)" />
                            @FormatType(t)
                        </label>
                    }
                </div>
            }
            else
            {
                <div class="detail-row">
                    <span class="detail-label">Rabat</span>
                    <span class="detail-value">@((Campaign.DiscountProcent * 100).ToString("0"))%</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Periode</span>
                    <span class="detail-value">@Campaign.StartDato.ToString("dd/MM/yyyy") – @Campaign.SlutDato.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Behandlingstyper</span>
                    <span class="detail-value">@(Campaign.ValidFor.Any() ? string.Join(", ", Campaign.ValidFor) : "Alle")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-label">Status</span>
                    <span class="badge @(IsActive ? "badge-scheduled" : "badge-cancelled")">
                        @(IsActive ? "Aktiv" : "Inaktiv")
                    </span>
                </div>
            }

            @if (errorMsg != null)
            {
                <p class="error-msg">@errorMsg</p>
            }

            <div class="modal-buttons">
                @if (Campaign != null)
                {
                    <button class="btn-slet" @onclick="Delete" disabled="@saving">Slet kampagne</button>
                }
                <button class="btn-annuller" @onclick="Cancel">@(Campaign == null ? "Annuller" : "Luk")</button>
                @if (Campaign == null)
                {
                    <button class="btn-gem" @onclick="Save" disabled="@saving">Opret</button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public CampaignDto? Campaign { get; set; }
    [Parameter] public DateTime? PreselectedDate { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    string navn = "";
    int discountPct = 10;
    DateTime startDato = DateTime.Today;
    DateTime slutDato = DateTime.Today.AddDays(7);
    List<AppointmentTypeEnum> validFor = [];
    string? errorMsg;
    bool saving;

    bool IsActive => Campaign != null &&
        DateTime.Today.Date >= Campaign.StartDato.Date &&
        DateTime.Today.Date <= Campaign.SlutDato.Date;

    protected override void OnParametersSet()
    {
        if (!IsVisible || Campaign != null) return;
        navn = "";
        discountPct = 10;
        startDato = PreselectedDate?.Date ?? DateTime.Today;
        slutDato = startDato.AddDays(7);
        validFor = [];
        errorMsg = null;
    }

    void ToggleType(AppointmentTypeEnum t, bool on)
    {
        if (on) validFor.Add(t);
        else validFor.Remove(t);
    }

    async Task Save()
    {
        errorMsg = null;
        if (string.IsNullOrWhiteSpace(navn)) { errorMsg = "Kampagnenavn er påkrævet."; return; }
        if (slutDato < startDato) { errorMsg = "Slutdato skal være efter startdato."; return; }
        saving = true;
        try
        {
            await AddCampaignUseCase.Run(new AddCampaignRequest(
                navn.Trim(),
                startDato,
                slutDato,
                discountPct / 100m,
                validFor
            ));
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    async Task Delete()
    {
        if (Campaign == null) return;
        saving = true;
        try
        {
            await RemoveCampaignUseCase.Run(Campaign.Id);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    async Task Cancel() => await OnCancelled.InvokeAsync();

    static string FormatType(AppointmentTypeEnum t) => t switch
    {
        AppointmentTypeEnum.Fysioterapi30Min          => "Fysioterapi 30 min",
        AppointmentTypeEnum.Fysioterapi45Min          => "Fysioterapi 45 min",
        AppointmentTypeEnum.Fysioterapi60Min          => "Fysioterapi 60 min",
        AppointmentTypeEnum.Sportsmassage30Min        => "Sportsmassage 30 min",
        AppointmentTypeEnum.Sportsmassage60Min        => "Sportsmassage 60 min",
        AppointmentTypeEnum.Akupunktur45Min           => "Akupunktur 45 min",
        AppointmentTypeEnum.KostvejledningFoerste     => "Kostvejledning - første",
        AppointmentTypeEnum.KostvejledningOpfoelgning => "Kostvejledning - opfølgning",
        AppointmentTypeEnum.Holdtraening60Min         => "Holdtræning 60 min",
        _ => t.ToString()
    };
}
