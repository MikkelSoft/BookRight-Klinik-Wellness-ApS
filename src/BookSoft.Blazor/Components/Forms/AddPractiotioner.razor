@inject IAddPractitionerUseCase AddPractitionerUseCase
@using BookSoft.Facade.UseCases
@using BookSoft.Facade.DTOs
@using BookSoft.Domain.Enums

<div class="modal-card">

    <h3>New Practitioner</h3>

    <div class="field">
        <label>First name *</label>
        <input type="text" @bind="firstName" placeholder="First name" />
    </div>
    <div class="field">
        <label>Middle name</label>
        <input type="text" @bind="middleName" placeholder="Middle name" />
    </div>
    <div class="field">
        <label>Last name *</label>
        <input type="text" @bind="lastName" placeholder="Last name" />
    </div>
    <div class="field">
        <label>Email *</label>
        <input type="email" @bind="email" placeholder="Email" />
    </div>
    <div class="field">
        <label>Phone number *</label>
        <input type="text" @bind="phoneNumber" placeholder="Phone number" />
    </div>
    <div class="field">
        <label>Specialty *</label>
        <input type="text" @bind="specialty" placeholder="E.g. Sports rehabilitation" />
    </div>
    <div class="field">
        <label>Authorization type *</label>
        <select @bind="autorisationsType">
            @foreach (var type in Enum.GetValues<AutorisationsTypeEnum>())
            {
                <option value="@type">@type</option>
            }
        </select>
    </div>

    @if (errorMessage != null)
    {
        <p class="error-msg">@errorMessage</p>
    }

    <div class="modal-buttons">
        <button class="btn-save" @onclick="Submit" disabled="@saving">
            @(saving ? "Saving..." : "Add practitioner")
        </button>
        <button class="btn-cancel" @onclick="OnClose">Cancel</button>
    </div>

</div>

@code {
    string firstName   = "";
    string middleName  = "";
    string lastName    = "";
    string email       = "";
    string phoneNumber = "";
    string specialty   = "";
    AutorisationsTypeEnum autorisationsType = AutorisationsTypeEnum.Fysioterapeut;

    bool saving = false;
    string? errorMessage;

    [Parameter] public EventCallback OnClose { get; set; }

    async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(firstName)   ||
            string.IsNullOrWhiteSpace(lastName)    ||
            string.IsNullOrWhiteSpace(email)       ||
            string.IsNullOrWhiteSpace(phoneNumber) ||
            string.IsNullOrWhiteSpace(specialty))
        {
            errorMessage = "Please fill in all required fields (*)";
            return;
        }

        saving = true;
        errorMessage = null;

        try
        {
            var request = new AddPractitionerRequest(
                firstName, middleName, lastName,
                email, phoneNumber, specialty,
                autorisationsType);

            await AddPractitionerUseCase.Run(request);
            await OnClose.InvokeAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
