@using BookSoft.Facade.DTOs
@using BookSoft.Facade.UseCases
@using BookSoft.Domain.Enums
@inject IAddPractitionerUseCase AddPractitionerUseCase
@inject IUpdatePractitionerUseCase UpdatePractitionerUseCase
@inject IRemovePractitionerUseCase RemovePractitionerUseCase

@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Cancel">
        <div class="modal" @onclick:stopPropagation>
            <h3>@(Practitioner == null ? "Ny behandler" : "Rediger behandler")</h3>

            <label>Fornavn</label>
            <input @bind="firstName" placeholder="Fornavn" />

            <label>Mellemnavn (valgfri)</label>
            <input @bind="middleNames" placeholder="Mellemnavn" />

            <label>Efternavn</label>
            <input @bind="lastName" placeholder="Efternavn" />

            <label>Email</label>
            <input @bind="email" type="email" placeholder="email@klinik.dk" />

            <label>Telefonnummer</label>
            <input @bind="phone" placeholder="+45 12 34 56 78" />

            <label>Speciale</label>
            <input @bind="specialty" placeholder="fx Fysioterapi, Akupunktur..." />

            <label>Autorisationstype</label>
            <select @bind="autorisationsType">
                @foreach (var val in Enum.GetValues<AutorisationsTypeEnum>())
                {
                    <option value="@val">@val</option>
                }
            </select>

            @if (errorMsg != null)
            {
                <p class="error-msg">@errorMsg</p>
            }

            <div class="modal-buttons">
                @if (Practitioner != null)
                {
                    <button class="btn-slet" @onclick="Delete" disabled="@saving">Slet</button>
                }
                <button class="btn-annuller" @onclick="Cancel">Annuller</button>
                <button class="btn-gem" @onclick="Save" disabled="@saving">Gem</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public PractitionerDto? Practitioner { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    string firstName = "", middleNames = "", lastName = "", email = "", phone = "", specialty = "";
    AutorisationsTypeEnum autorisationsType = AutorisationsTypeEnum.Fysioterapeut;
    string? errorMsg;
    bool saving;

    protected override void OnParametersSet()
    {
        if (!IsVisible) return;
        if (Practitioner != null)
        {
            firstName = Practitioner.FirstName;
            middleNames = "";
            lastName = Practitioner.LastName;
            email = Practitioner.Email;
            phone = Practitioner.PhoneNumber;
            specialty = Practitioner.Specialty;
            autorisationsType = Practitioner.AutorisationsType;
        }
        else
        {
            firstName = middleNames = lastName = email = phone = specialty = "";
            autorisationsType = AutorisationsTypeEnum.Fysioterapeut;
        }
        errorMsg = null;
    }

    async Task Save()
    {
        errorMsg = null;
        if (string.IsNullOrWhiteSpace(firstName) || string.IsNullOrWhiteSpace(lastName))
        {
            errorMsg = "Fornavn og efternavn er påkrævet.";
            return;
        }
        saving = true;
        try
        {
            if (Practitioner == null)
                await AddPractitionerUseCase.Run(new AddPractitionerRequest(firstName.Trim(), middleNames.Trim(), lastName.Trim(), email.Trim(), phone.Trim(), specialty.Trim(), autorisationsType));
            else
                await UpdatePractitionerUseCase.Run(new UpdatePractitionerRequest(Practitioner.Id, firstName.Trim(), middleNames.Trim(), lastName.Trim(), email.Trim(), phone.Trim(), specialty.Trim(), autorisationsType));

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    async Task Delete()
    {
        if (Practitioner == null) return;
        saving = true;
        try
        {
            await RemovePractitionerUseCase.Run(Practitioner.Id);
            await OnSaved.InvokeAsync();
        }
        catch (Exception ex) { errorMsg = ex.Message; }
        finally { saving = false; }
    }

    async Task Cancel() => await OnCancelled.InvokeAsync();
}
